# BalVoi public website (story URLs)
BALVOI_SITE_URL=https://staging.balvoi.com
# NewsGenie API engine (MongoDB articles)
BALVOI_API_URL=https://api.staging.newsgenie.ai
BALVOI_API_KEY=your_balvoi_api_key_here
# Podcast fetch: article limit and optional since override for testing (ISO-8601 UTC)
BALVOI_ARTICLE_LIMIT=200
BALVOI_SINCE_OVERRIDE=
# Local test mode: use demo articles when API returns nothing
BALVOI_ALLOW_DEMO_ARTICLES=false
# Only pick articles published in the last N minutes (fallback: latest available)
BALVOI_ARTICLE_WINDOW_MINUTES=60
BALVOI_STORY_COOLDOWN_MINUTES=360

# AI: OpenAI for script rewrite, translation, primers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ElevenLabs TTS (required for real audio)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# AWS Bedrock (optional future primary)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Backend
PORT=3001
SCHEDULER_ENABLED=true                    # process at UTC :51; publish at next :00
STORAGE_PATH=storage
PUBLIC_BASE_URL=https://podcast.example.com
PODCAST_OWNER_NAME=BalVoi:60
PODCAST_OWNER_EMAIL=podcasts@example.com
PODCAST_ARTWORK_BASE_URL=https://podcast.example.com/artwork

# Pipeline: all 8 editions, ~30 min episodes
PIPELINE_EDITIONS=en,es,pt,fr,de,ar,ru,tr
DRY_RUN=false
MIN_PUBLISH_DURATION_SECONDS=600
LANGUAGE_WORKER_CONCURRENCY=4
TRANSLATION_CONCURRENCY=4
TTS_REQUEST_CONCURRENCY=3
MERGE_CONCURRENCY=2

# Optional Megaphone publication. Repeat token/network/podcast values for:
# EN, ES, PT, FR, DE, AR, RU, TR.
MEGAPHONE_ENABLED=false
MEGAPHONE_API_TOKEN_EN=
MEGAPHONE_NETWORK_ID_EN=
MEGAPHONE_PODCAST_ID_EN=
